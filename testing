<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Editable Warehouse Map</title>

  <style>
    html, body {
      height: 100%;
      margin: 0;
      font-family: Arial, sans-serif;
      background: #f4f4f4;
    }

    #toolbar {
      height: 50px;
      background: #222;
      color: #fff;
      display: flex;
      align-items: center;
      padding: 0 15px;
    }

    #toolbar button {
      margin-right: 10px;
      padding: 6px 10px;
      border: none;
      cursor: pointer;
      background: #4caf50;
      color: #fff;
      border-radius: 4px;
    }

    #toolbar span {
      margin-left: auto;
      font-size: 13px;
      opacity: 0.8;
    }

    #canvas-wrapper {
      height: calc(100% - 50px);
      display: flex;
      justify-content: center;
      align-items: center;
    }

    svg {
      background-color: #ffffff;
      border: 2px solid #333;
    }

    .zone {
      cursor: move;
      stroke: #333;
      stroke-width: 2;
      fill-opacity: 0.6;
    }

    .zone text {
      pointer-events: none;
      font-size: 12px;
      fill: #000;
      font-weight: bold;
    }

    .receiving { fill: #81d4fa; }
    .storage   { fill: #c5e1a5; }
    .picking   { fill: #ffcc80; }
    .shipping  { fill: #ef9a9a; }

    .selected {
      stroke-dasharray: 5,5;
    }
  </style>
</head>

<body>
  <div id="toolbar">
    <button onclick="addZone('storage')">Add Storage</button>
    <button onclick="addZone('picking')">Add Picking</button>
    <button onclick="addZone('receiving')">Add Receiving</button>
    <button onclick="addZone('shipping')">Add Shipping</button>
    <span>Warehouse size: 200m × 200m</span>
  </div>

  <div id="canvas-wrapper">
    <!-- 1px = 1 meter scale -->
    <svg id="warehouseMap" width="800" height="800" viewBox="0 0 200 200">
      <!-- Warehouse boundary -->
      <rect x="0" y="0" width="200" height="200"
            fill="none" stroke="#000" stroke-width="2" />

      <!-- Grid -->
      <g stroke="#ddd" stroke-width="0.2">
        <script>
          for (let i = 0; i <= 200; i += 10) {
            document.write(`<line x1="${i}" y1="0" x2="${i}" y2="200"/>`);
            document.write(`<line x1="0" y1="${i}" x2="200" y2="${i}"/>`);
          }
        </script>
      </g>

      <!-- Zones container -->
      <g id="zones"></g>
    </svg>
  </div>

  <script>
    const svg = document.getElementById("warehouseMap");
    const zonesGroup = document.getElementById("zones");

    let selectedZone = null;
    let offset = { x: 0, y: 0 };

    const zoneDefaults = {
      receiving: { w: 30, h: 25, class: "receiving", label: "Receiving" },
      storage:   { w: 50, h: 50, class: "storage", label: "Storage" },
      picking:   { w: 40, h: 30, class: "picking", label: "Picking" },
      shipping:  { w: 30, h: 25, class: "shipping", label: "Shipping" }
    };

    function addZone(type) {
      const z = zoneDefaults[type];
      const g = document.createElementNS("http://www.w3.org/2000/svg", "g");

      const rect = document.createElementNS("http://www.w3.org/2000/svg", "rect");
      rect.setAttribute("x", 10);
      rect.setAttribute("y", 10);
      rect.setAttribute("width", z.w);
      rect.setAttribute("height", z.h);
      rect.setAttribute("class", `zone ${z.class}`);

      const text = document.createElementNS("http://www.w3.org/2000/svg", "text");
      text.setAttribute("x", 14);
      text.setAttribute("y", 24);
      text.textContent = z.label;

      g.appendChild(rect);
      g.appendChild(text);
      zonesGroup.appendChild(g);

      makeDraggable(g, rect);
    }

    function makeDraggable(group, rect) {
      group.addEventListener("mousedown", startDrag);

      function startDrag(e) {
        selectedZone = group;
        deselectAll();
        rect.classList.add("selected");

        offset.x = e.offsetX - rect.getAttribute("x");
        offset.y = e.offsetY - rect.getAttribute("y");

        svg.addEventListener("mousemove", drag);
        svg.addEventListener("mouseup", endDrag);
      }

      function drag(e) {
        if (!selectedZone) return;
        let x = (e.offsetX * 200) / 800 - offset.x;
        let y = (e.offsetY * 200) / 800 - offset.y;

        x = Math.max(0, Math.min(200 - rect.getAttribute("width"), x));
        y = Math.max(0, Math.min(200 - rect.getAttribute("height"), y));

        rect.setAttribute("x", x);
        rect.setAttribute("y", y);

        group.querySelector("text").setAttribute("x", parseFloat(x) + 4);
        group.querySelector("text").setAttribute("y", parseFloat(y) + 14);
      }

      function endDrag() {
        svg.removeEventListener("mousemove", drag);
        svg.removeEventListener("mouseup", endDrag);
        selectedZone = null;
      }
    }

    function deselectAll() {
      document.querySelectorAll(".zone").forEach(z => z.classList.remove("selected"));
    }
  </script>
</body>
</html>
